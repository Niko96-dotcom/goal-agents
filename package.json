{
  "name": "goal-agents",
  "version": "0.1.0",
  "description": "Codex-style /goal for Cursor, OpenCode, Pi, and Command Code",
  "type": "module",
  "scripts": {
    "build:cli": "npm run build -C \"${OPENCODE_GOAL:-$HOME/Documents/opencode goal}\"",
    "install": "bash scripts/install.sh",
    "bootstrap": "bash scripts/bootstrap.sh",
    "install:cli": "bash scripts/install-cli.sh",
    "install:cursor": "bash scripts/install-cursor-skill.sh --global",
    "install:pi": "bash scripts/install-pi-skill.sh --global && bash scripts/install-pi-extension.sh",
    "install:commandcode": "bash scripts/install-commandcode-skill.sh --global",
    "install:all": "npm run install:cursor && npm run install:pi && npm run install:commandcode",
    "test": "bash scripts/e2e-smoke.sh",
    "test:cli": "bash scripts/e2e-cli-only.sh"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Niko96-dotcom/goal-agents.git"
  },
  "keywords": [
    "goal",
    "cursor",
    "opencode",
    "pi",
    "commandcode",
    "agent",
    "codex"
  ]
}
